# Example Terraform variables for dev environment
# Copy this to terraform.tfvars and customize as needed

aws_region   = "us-west-1"
project      = "zerotrust-ecs"
environment  = "dev"

# VPC Configuration
vpc_cidr = "10.0.0.0/16"

# Availability Zones (us-west-1 has only 2 AZs)
azs = ["us-west-1a", "us-west-1b"]

# Public Subnets (for ALB, NAT Gateway)
public_subnet_cidrs = [
  "10.0.1.0/24",   # us-west-1a
  "10.0.2.0/24"    # us-west-1b
]

# Private Subnets (for ECS tasks, RDS)
private_subnet_cidrs = [
  "10.0.11.0/24",  # us-west-1a
  "10.0.12.0/24"   # us-west-1b
]

